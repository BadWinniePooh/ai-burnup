# ─────────────────────────────────────────────────────────────────────────────
# Burnup – environment variable reference
#
# Copy this file to .env and fill in the required values, then run:
#   docker compose up --build
#
# Docker Compose reads .env automatically and substitutes ${VAR} references
# in docker-compose.yml. The variables are then passed into the containers.
#
# In ASP.NET Core, config section separators use double-underscore (__) instead
# of the colon (:) used in appsettings.json — e.g. Jwt:Secret → Jwt__Secret.
# ─────────────────────────────────────────────────────────────────────────────


# ── PostgreSQL ────────────────────────────────────────────────────────────────

# Password for the internal burnup database user. Must be set before first run.
# Generate one with: openssl rand -base64 32
Postgres__Password=replace-this-with-a-strong-random-database-password


# ── JWT ───────────────────────────────────────────────────────────────────────

# Secret used to sign JWT tokens. Must be at least 32 characters.
# Generate one with: openssl rand -base64 48
Jwt__Secret=replace-this-with-a-long-random-string-at-least-32-chars

# How long a token stays valid before the user is asked to log in again.
# Default: 24
# Jwt__ExpiryHours=24

# These are embedded in the token and validated on each request.
# Only change if you run multiple services that share the same token.
# Defaults: BurnupApi / BurnupApp
# Jwt__Issuer=BurnupApi
# Jwt__Audience=BurnupApp


# ── Admin seed ────────────────────────────────────────────────────────────────

# On first startup the application creates (or promotes) a user with the admin
# role using these credentials. Safe to remove from .env once the account exists.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme


# ── Application URL ───────────────────────────────────────────────────────────

# Public URL where the frontend is reachable. Used to build the password-reset
# link that is sent by email (or shown in the API response when SMTP is off).
AppUrl=http://localhost:8080

# ── Traefik (docker-compose.traefik.yml only) ────────────────────────────────

# The public hostname Traefik should route to this app.
# DOMAIN=burnup.example.com

# Name of the external Docker network Traefik is attached to. Default: traefik
# TRAEFIK_NETWORK=traefik

# Name of the Traefik cert resolver for Let's Encrypt. Default: letsencrypt
# TRAEFIK_CERTRESOLVER=letsencrypt


# ── SMTP (optional) ───────────────────────────────────────────────────────────

# When Smtp__Host is empty the app runs in dev mode: the reset link is returned
# directly in the API response instead of being emailed.

# Hostname of the SMTP server (e.g. smtp.mailgun.org, smtp.sendgrid.net).
# Smtp__Host=smtp.example.com

# SMTP port. Common values: 587 (STARTTLS), 465 (SSL). Default: 587
# Smtp__Port=587

# SMTP credentials.
# Smtp__User=apikey
# Smtp__Pass=your-smtp-password-or-api-key

# The address that appears in the From field of outgoing emails.
# Default: noreply@burnup.app
# Smtp__From=noreply@example.com
