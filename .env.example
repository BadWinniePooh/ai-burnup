# ─────────────────────────────────────────────────────────────────────────────
# Burnup – environment variable reference
#
# Copy this file to .env (never commit .env) and fill in the values.
# In ASP.NET Core, section separators use double-underscore (__) instead of
# the colon (:) used in appsettings.json.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Format: Host=<host>;Port=<port>;Database=<db>;Username=<user>;Password=<pass>
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=burnup;Username=burnup;Password=changeme


# ── JWT ───────────────────────────────────────────────────────────────────────

# Secret used to sign JWT tokens. Must be at least 32 characters.
# Generate one with: openssl rand -base64 48
Jwt__Secret=replace-this-with-a-long-random-string-at-least-32-chars

# How long a token stays valid before the user is asked to log in again.
# Default: 24
Jwt__ExpiryHours=24

# These are embedded in the token and validated on each request.
# Only change if you run multiple services that share the same token.
# Defaults: BurnupApi / BurnupApp
# Jwt__Issuer=BurnupApi
# Jwt__Audience=BurnupApp


# ── Admin seed ────────────────────────────────────────────────────────────────

# If these are set on first startup the application creates (or promotes) a
# user with the admin role. Safe to leave unset in production once the admin
# account exists.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme


# ── Application URL ───────────────────────────────────────────────────────────

# Public URL of the frontend. Used to build the password-reset link that is
# sent by email (or shown in the response when SMTP is not configured).
AppUrl=http://localhost:5500


# ── SMTP (optional) ───────────────────────────────────────────────────────────

# When Smtp__Host is empty the application runs in dev mode: instead of
# sending an email it returns the reset link directly in the API response.
# Fill these in to enable real email delivery.

# Hostname of the SMTP server (e.g. smtp.mailgun.org, smtp.sendgrid.net).
# Smtp__Host=smtp.example.com

# SMTP port. Common values: 587 (STARTTLS), 465 (SSL). Default: 587
# Smtp__Port=587

# SMTP credentials.
# Smtp__User=apikey
# Smtp__Pass=your-smtp-password-or-api-key

# The address that appears in the From field of outgoing emails.
# Default: noreply@burnup.app
# Smtp__From=noreply@example.com
